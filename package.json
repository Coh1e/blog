{
  "name": "unauthorized",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite-react-ssg build && node scripts/generate-seo-files.mjs && pagefind --site dist --output-path dist/pagefind && node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "check:size": "node scripts/check-bundle-size.mjs",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "deploy": "npm run build && wrangler pages deploy dist",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.1.0",
    "vite-react-ssg": "^0.7.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "gray-matter": "^4.0.3",
    "happy-dom": "^15.11.7",
    "pagefind": "^1.5.2",
    "patch-package": "^8.0.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8",
    "wrangler": "^4.88.0"
  }
}
